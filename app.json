{
  "expo": {
    "name": "Finanças",
    "slug": "financaspessoais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0b"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.davi.financaspessoais",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID para desbloquear o app de finanças pessoais.",
        "NSCameraUsageDescription": "Permita o acesso à câmera para anexar comprovantes às transações.",
        "NSPhotoLibraryUsageDescription": "Permita o acesso à galeria para anexar comprovantes às transações.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.davi.financaspessoais",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID para desbloquear o app de finanças pessoais."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita acesso à galeria para anexar comprovantes.",
          "cameraPermission": "Permita acesso à câmera para tirar foto de comprovantes."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00d4aa"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/31f97ff9-a4cf-4fa7-a5a9-3e879d9df425"
    },
    "extra": {
      "eas": {
        "projectId": "31f97ff9-a4cf-4fa7-a5a9-3e879d9df425"
      }
    },
    "owner": "xocoax"
  }
}
